# Set default behavior for line endings (auto-detection)
* text=auto

# Force LF for Python source files (standard for cross-platform Python)
*.py text eol=lf

# Configuration and documentation files
*.json text
*.yaml text
*.yml text
*.md text

# Binary files - Git should leave these untouched
*.jpg binary
*.png binary
*.gif binary
*.pyc binary
*.db binary
*.sqlite binary